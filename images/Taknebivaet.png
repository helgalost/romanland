<svg xmlns="http://www.w3.org/2000/svg" width="400" height="600" viewBox="0 0 400 600">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6B4C7A;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3D2855;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="600" fill="url(#grad1)"/>
  <text x="200" y="280" font-family="Georgia, serif" font-size="28" fill="#FFD7E0" text-anchor="middle" font-weight="bold">Так не бывает:</text>
  <text x="200" y="320" font-family="Georgia, serif" font-size="24" fill="#FFD7E0" text-anchor="middle">мужчина из сна</text>
  <text x="200" y="550" font-family="Arial, sans-serif" font-size="16" fill="#FFFFFF" text-anchor="middle">Елена Ночь</text>
  <circle cx="200" cy="150" r="60" fill="#FF6B9D" opacity="0.3"/>
